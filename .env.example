# Application environment template. The SDK does not load this file automatically.

# LLM
OPENAI_API_KEY=your-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini

# Embeddings (falls back to OPENAI_API_KEY / OPENAI_BASE_URL if not set)
EMBEDDING_API_KEY=your-api-key-here
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_MODEL=text-embedding-3-small

# VLM — vision analysis for figures (falls back to OPENAI_API_KEY / OPENAI_BASE_URL if not set)
VLM_API_KEY=your-api-key-here
VLM_BASE_URL=https://api.openai.com/v1
VLM_MODEL=gpt-4.1-mini

# Reranker (falls back to OPENAI_API_KEY / OPENAI_BASE_URL if not set)
RERANK_API_KEY=your-api-key-here
RERANK_BASE_URL=https://api.openai.com/v1
RERANK_MODEL=BAAI/bge-reranker-v2-m3
RERANK_ENDPOINT=/rerank

# Agent state storage
POSTGRES_DSN=postgresql://science_agent:science-agent-dev-password@localhost:5432/science_agent
# Set explicitly to enable PostgreSQL integration tests. It may point at the
# local development database because tests use isolated agent ids.
POSTGRES_TEST_DSN=postgresql://science_agent:science-agent-dev-password@localhost:5432/science_agent

# Milvus Standalone
MILVUS_URI=http://localhost:19530
MILVUS_COLLECTION_NAME=paper_chunks
WIKI_MILVUS_COLLECTION_NAME=wiki_pages
